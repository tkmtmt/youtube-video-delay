{
  "manifest_version": 3,
  "name": "YouTube Video Sync",
  "version": "0.1.0",
  "description": "Bluetoothイヤホン用にYouTubeの音ズレを補正する拡張",
  "permissions": ["storage"],
  "host_permissions": ["https://www.youtube.com/*"],
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}